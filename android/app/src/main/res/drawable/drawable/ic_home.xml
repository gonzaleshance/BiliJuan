<?xml version="1.0" encoding="utf-8"?>
<!-- ic_home.xml
     Home/house icon. Used in the bottom navigation bar as the primary
     marketplace feed tab. The "Digital Hearth" metaphor makes this icon
     especially meaningful — it is the anchor of the app.
     24x24dp. Tint: #1A1C1A default; #A04100 when active tab. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="#1A1C1A">

    <!-- House outline -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#1A1C1A"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M3,9.5 L12,3 L21,9.5 V20 A1,1 0,0,1 20,21 H15 V15 H9 V21 H4 A1,1 0,0,1 3,20 Z" />

</vector>
