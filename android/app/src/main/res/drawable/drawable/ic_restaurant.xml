<?xml version="1.0" encoding="utf-8"?>
<!-- ic_restaurant.xml
     Fork and knife / restaurant icon. Used in the home screen category
     filter chips for food/meal listings, and in the seller product listing
     section headers. Reinforces the food marketplace identity.
     24x24dp. Tint: #1A1C1A default; #A04100 on active category. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="#1A1C1A">

    <!-- Fork (left) -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#1A1C1A"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="M3,2 L3,8" />

    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#1A1C1A"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="M5,2 L5,8" />

    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#1A1C1A"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="M7,2 L7,8" />

    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#1A1C1A"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="M5,8 L5,22" />

    <!-- Curved top bridge of fork -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#1A1C1A"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M3,8 C3,10 7,10 7,8" />

    <!-- Knife (right) -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#1A1C1A"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M19,2 C19,2 21,4 21,8 C21,10 20,11 19,11 L19,22" />

</vector>
