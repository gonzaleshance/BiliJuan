<?xml version="1.0" encoding="utf-8"?>
<!-- bg_circle_image.xml
     Circular image placeholder/clip background. Used for vendor avatar
     and seller profile images. Neutral surface-container #E8E8E4 fill
     acts as a graceful placeholder before images load.
     Apply as background to an ImageView clipped to circle via ShapeableImageView
     or set as the background on a circular FrameLayout container. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <solid android:color="#E8E8E4" />

</shape>
