<?xml version="1.0" encoding="utf-8"?>
<!-- ic_receipt.xml
     Receipt / order history icon. Used in the bottom navigation bar
     for the Orders / History tab for customers, and in the seller
     dashboard navigation for the Sales History section.
     24x24dp. Tint: #1A1C1A default; #A04100 when active tab. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="#1A1C1A">

    <!-- Receipt body -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#1A1C1A"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M4,2 H20 A1,1 0,0,1 21,3 V21 L18,19 L15,21 L12,19 L9,21 L6,19 L3,21 V3 A1,1 0,0,1 4,2 Z" />

    <!-- Line items -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#1A1C1A"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M8,10 H16" />

    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#1A1C1A"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M8,14 H12" />

</vector>
