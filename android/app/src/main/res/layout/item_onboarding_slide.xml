<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingHorizontal="40dp"
    android:background="@color/background">

    <TextView
        android:id="@+id/tvSlideEmoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🛒"
        android:textSize="100sp"
        android:layout_marginBottom="48dp"/>

    <TextView
        android:id="@+id/tvSlideTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Freshness at Your Door"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:letterSpacing="-0.02"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvSlideDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Discover local flavors and fresh harvests from sellers right in your neighborhood."
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:lineSpacingExtra="6dp"/>

</LinearLayout>
