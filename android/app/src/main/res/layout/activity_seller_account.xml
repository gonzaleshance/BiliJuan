<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- Premium Header (Matches Customer Style) -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#27AE60"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="48dp"
            android:paddingBottom="40dp"
            android:paddingHorizontal="24dp"
            android:gravity="center">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSettings"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_alignParentEnd="true"
                    android:text="Edit Store"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#27AE60"
                    android:backgroundTint="#FFFFFF"
                    app:cornerRadius="18dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:elevation="2dp"/>
            </RelativeLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="60dp"
                app:cardElevation="8dp"
                app:strokeWidth="4dp"
                app:strokeColor="#FFFFFF"
                app:cardBackgroundColor="#EAFAF1">
                
                <ImageView
                    android:id="@+id/ivStoreAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_store"
                    app:tint="#27AE60"
                    android:padding="28dp"
                    android:scaleType="centerInside"/>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvStoreName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="16dp"
                android:letterSpacing="-0.01"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Verified Seller"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#CCFFFFFF"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_white_circle"
                android:backgroundTint="#33FFFFFF"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"/>

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="-32dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_top_rounded"
            android:paddingHorizontal="24dp"
            android:paddingTop="36dp"
            android:paddingBottom="100dp"
            android:elevation="4dp">

            <!-- Store Details Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STORE DETAILS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#B2BEC3"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="4dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F2F6"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_phone"
                            app:tint="#27AE60"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Phone"
                            android:textSize="14sp"
                            android:textColor="#636E72"
                            android:layout_marginStart="16dp"/>
                        <TextView
                            android:id="@+id/tvPhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#2D3436"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F8F9FA" android:layout_marginVertical="18dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_location"
                            app:tint="#27AE60"
                            android:layout_marginTop="2dp"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Address"
                            android:textSize="14sp"
                            android:textColor="#636E72"
                            android:layout_marginStart="16dp"/>
                        <TextView
                            android:id="@+id/tvAddress"
                            android:layout_width="160dp"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#2D3436"
                            android:gravity="end"
                            android:maxLines="2"
                            android:ellipsize="end"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Menu Management Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="4dp">
                <TextView
                    android:id="@+id/tvMyMenuLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="MY PRODUCTS"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#B2BEC3"
                    android:letterSpacing="0.1"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddItem"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="+ Add Item"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#27AE60"
                    android:backgroundTint="#FFFFFF"
                    app:cornerRadius="16dp"
                    app:strokeColor="#27AE60"
                    app:strokeWidth="1dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/emptyMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No products posted yet."
                android:textSize="14sp"
                android:textColor="#B2BEC3"
                android:gravity="center"
                android:paddingVertical="32dp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="32dp"/>

            <!-- Profile Actions -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Sign Out"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#EB4D4B"
                android:backgroundTint="#FFFFFF"
                app:strokeColor="#EB4D4B"
                app:strokeWidth="1.5dp"
                app:cornerRadius="30dp"
                app:icon="@drawable/ic_logout"
                app:iconTint="#EB4D4B"
                app:iconPadding="12dp"
                app:iconGravity="textStart"
                app:elevation="0dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Version 1.0.4 • BiliJuan Marketplace"
                android:textSize="11sp"
                android:textColor="#B2BEC3"
                android:gravity="center"
                android:layout_marginTop="24dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/storeNav"
        layout="@layout/layout_store_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>