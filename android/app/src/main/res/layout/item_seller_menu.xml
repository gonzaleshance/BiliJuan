<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Top row: image + info + badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <!-- Product image -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivProduct"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:scaleType="centerCrop"
                android:background="@color/surface_variant"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.BiliJuan.Small"
                android:layout_marginEnd="14dp"/>

            <!-- Name + price + stock -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                    <!-- Active / Out of Stock badge -->
                    <TextView
                        android:id="@+id/tvAvailabilityBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:background="@drawable/bg_badge_active"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/surface_variant"
            android:layout_marginBottom="10dp"/>

        <!-- Action buttons: View | Edit | Delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnView"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="View"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:backgroundTint="@color/surface_variant"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_search"
                app:iconTint="@color/text_secondary"
                app:iconSize="14dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="6dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEdit"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Edit"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:backgroundTint="@color/surface_variant"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_edit"
                app:iconTint="@color/text_secondary"
                app:iconSize="14dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="6dp"/>

            <!-- Delete -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:backgroundTint="#FDECEA"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_delete"
                app:iconTint="@color/error"
                app:iconSize="16dp"
                app:iconGravity="textStart"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="10dp"/>

            <!-- Availability toggle -->
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchAvailable"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:visibility="gone"/>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>