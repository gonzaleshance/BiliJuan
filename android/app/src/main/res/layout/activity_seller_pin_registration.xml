<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Full-screen OSMDroid map -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"/>

    <!-- Fixed Center Pointer (Optimized UX Pointer) -->
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:paddingBottom="48dp"
        android:elevation="12dp">
        
        <!-- Outer Circle / Target area -->
        <View
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_white_circle"
            android:backgroundTint="#3327AE60"
            android:alpha="0.5"/>

        <!-- The Pin -->
        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_location"
            app:tint="#EB4D4B" />
            
        <!-- Precise tip dot -->
        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_white_circle"
            android:backgroundTint="#EB4D4B"/>
    </FrameLayout>

    <!-- Top card: back button + Search + instruction -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:layout_margin="12dp"
        android:background="@drawable/bg_card_white"
        android:backgroundTint="#EEFFFFFF"
        android:padding="14dp"
        android:elevation="6dp">

        <!-- Back + title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@android:color/transparent"
                app:tint="#27AE60"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pin Your Store Location"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2D3436"/>

            <!-- My Location button -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnMyLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_location"
                app:fabSize="mini"
                app:backgroundTint="#27AE60"
                app:tint="#FFFFFF"
                app:elevation="2dp"/>
        </LinearLayout>

        <!-- Search Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_search_white"
            android:backgroundTint="#F1F2F6"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                app:tint="#B2BEC3"/>

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Search street, city, or landmark"
                android:textSize="14sp"
                android:textColor="#2D3436"
                android:maxLines="1"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:layout_marginStart="10dp"
                android:paddingEnd="8dp"/>

            <ProgressBar
                android:id="@+id/progressSearch"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:visibility="gone"
                android:indeterminateTint="#27AE60"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvInstruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Drag the map to position your store exactly under the red pin."
            android:textSize="12sp"
            android:textColor="#636E72"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_surface_section"
            android:padding="10dp">
            
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_location"
                app:tint="#27AE60"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvAddress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Detecting location..."
                android:textSize="12sp"
                android:textColor="#2D3436"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"/>
            
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerifyExternal"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Verify"
                android:textSize="11sp"
                android:textColor="#27AE60"
                app:icon="@drawable/google"
                app:iconTint="@null"
                app:iconSize="14dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="8dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Bottom confirm button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bg_card_top_rounded"
        android:backgroundTint="#FFFFFF"
        android:elevation="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmPin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="This is my exact store location"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#27AE60"
            app:cornerRadius="16dp"
            app:elevation="4dp"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
