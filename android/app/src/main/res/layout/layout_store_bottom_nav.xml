<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@color/surface"
    android:elevation="16dp">

    <!-- Shadow line at top -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/surface_variant"/>

    <!-- Left tabs: Home + Orders -->
    <LinearLayout
        android:id="@+id/navLeft"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- Home -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/iconHome"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_home"
                app:tint="@color/primary"/>

            <TextView
                android:id="@+id/labelHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <!-- Orders -->
        <LinearLayout
            android:id="@+id/navOrders"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/iconOrders"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_receipt"
                app:tint="@color/text_hint"/>

            <TextView
                android:id="@+id/labelOrders"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Orders"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/text_hint"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <!-- Center spacer for FAB -->
        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>

        <!-- Reports -->
        <LinearLayout
            android:id="@+id/navReports"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/iconReports"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_chart"
                app:tint="@color/text_hint"/>

            <TextView
                android:id="@+id/labelReports"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reports"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/text_hint"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <!-- Store -->
        <LinearLayout
            android:id="@+id/navStore"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/iconStore"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_store"
                app:tint="@color/text_hint"/>

            <TextView
                android:id="@+id/labelStore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Store"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/text_hint"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Floating center Post FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabPost"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="12dp"
        android:src="@drawable/ic_plus_circle"
        app:backgroundTint="@color/primary"
        app:tint="@color/on_primary"
        app:fabSize="normal"
        app:elevation="8dp"
        app:borderWidth="0dp"/>

</RelativeLayout>