<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_seller_delivery_map.xml
    Place in: app/src/main/res/layout/activity_seller_delivery_map.xml

    Full-screen OSMDroid map with:
      • Floating back button (top-left)
      • Order summary card (bottom, always visible)
      • "Mark Delivered" action button (visible only when status = ON_THE_WAY)
      • "Call Customer" + "Open in Google Maps" secondary actions
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ── Full-screen map ───────────────────────────────────────────────── -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"/>

    <!-- ── Back button (floating, top-left) ─────────────────────────────── -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:layout_anchor="@id/mapView"
        app:layout_anchorGravity="top|start"
        app:srcCompat="@drawable/ic_arrow_back"
        app:backgroundTint="@color/surface"
        app:tint="@color/text_primary"
        app:fabSize="mini"
        app:elevation="4dp"
        android:contentDescription="Back"/>

    <!-- ── Bottom info sheet ─────────────────────────────────────────────── -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="12dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Order ID + Status badge row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvOrderId"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:text="Order #------"/>

                <TextView
                    android:id="@+id/tvOrderStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_primary"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:backgroundTint="@color/primary"
                    android:background="@drawable/bg_primary_pill"
                    android:text="ON THE WAY"/>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/surface_variant"
                android:layout_marginBottom="12dp"/>

            <!-- Customer name row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_person"
                    app:tint="@color/primary"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tvCustomerName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:text="Customer Name"/>
            </LinearLayout>

            <!-- Address row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_location"
                    app:tint="@color/text_secondary"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tvCustomerAddress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:text="Customer address"/>

                <TextView
                    android:id="@+id/tvOrderTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:layout_marginStart="8dp"
                    android:text="₱0.00"/>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/surface_variant"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="14dp"/>

            <!-- Action buttons row: Call + Google Maps -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCallCustomer"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Call Customer"
                    android:textSize="12sp"
                    android:textColor="@color/primary"
                    app:strokeColor="@color/primary"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/ic_phone"
                    app:iconTint="@color/primary"
                    app:iconSize="16dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenGoogleMaps"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Navigate"
                    android:textSize="12sp"
                    android:textColor="@color/primary"
                    app:strokeColor="@color/primary"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/ic_location"
                    app:iconTint="@color/primary"
                    app:iconSize="16dp"/>
            </LinearLayout>

            <!-- Mark Delivered button — only shown when status = ON_THE_WAY -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewMap"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="View Map"
                android:textSize="12sp"
                android:textColor="@color/primary"
                app:strokeColor="@color/primary"
                app:cornerRadius="10dp"
                app:icon="@drawable/ic_location"
                app:iconTint="@color/primary"
                app:iconSize="16dp"
                android:visibility="gone"/>

            <!-- Mark Delivered button — only shown when status = ON_THE_WAY -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMarkDelivered"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="✓  Mark as Delivered"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/on_primary"
                android:backgroundTint="@color/primary"
                app:cornerRadius="12dp"
                app:elevation="0dp"
                android:visibility="visible"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>