<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface"
    android:paddingHorizontal="24dp"
    android:paddingTop="12dp"
    android:paddingBottom="32dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@color/surface_variant"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Report this listing"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select the reason for your report. All reports are reviewed by our admin team."
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="16dp"/>

    <ListView
        android:id="@+id/listReasons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:divider="@color/surface_variant"
        android:dividerHeight="1dp"
        android:layout_marginBottom="20dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmitReport"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Submit Report"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/on_primary"
        android:backgroundTint="@color/error"
        app:cornerRadius="26dp"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancelReport"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Cancel"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:backgroundTint="@color/surface"
        app:strokeColor="@color/surface_variant"
        app:strokeWidth="1dp"
        app:cornerRadius="24dp"/>

</LinearLayout>