<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF9F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="80dp"
        android:paddingBottom="48dp">

        <!-- Brand -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BiliJuan"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#A04100"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="40dp"/>

        <!-- Badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COMMUNITY DRIVEN"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#795950"
            android:background="@drawable/bg_chip_secondary"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:layout_marginBottom="12dp"/>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join the Digital Hearth."
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1A1C1A"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create your account to start buying or selling local."
            android:textSize="14sp"
            android:textColor="#77574D"
            android:layout_marginBottom="32dp"/>

        <!-- ── Full Name ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full Name"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#5A4136"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxBackgroundColor="#F4F4F0"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="2dp"
            app:boxStrokeColor="#A04100"
            android:layout_marginBottom="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Juan dela Cruz"
                android:inputType="textPersonName"
                android:paddingHorizontal="20dp"
                android:background="@null"
                android:textColor="#1A1C1A"
                android:textSize="14sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Email ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#5A4136"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxBackgroundColor="#F4F4F0"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="2dp"
            app:boxStrokeColor="#A04100"
            android:layout_marginBottom="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="hello@bilijuan.com"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="20dp"
                android:background="@null"
                android:textColor="#1A1C1A"
                android:textSize="14sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Phone ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phone Number"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#5A4136"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxBackgroundColor="#F4F4F0"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="2dp"
            app:boxStrokeColor="#A04100"
            android:layout_marginBottom="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="09XX XXX XXXX"
                android:inputType="phone"
                android:paddingHorizontal="20dp"
                android:background="@null"
                android:textColor="#1A1C1A"
                android:textSize="14sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Password ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#5A4136"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxBackgroundColor="#F4F4F0"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="2dp"
            app:boxStrokeColor="#A04100"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="#8E7164"
            android:layout_marginBottom="28dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Min. 6 characters"
                android:inputType="textPassword"
                android:paddingHorizontal="20dp"
                android:background="@null"
                android:textColor="#1A1C1A"
                android:textSize="14sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Address Section Header ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOUR ADDRESS IN SARANAY"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#77574D"
            android:letterSpacing="0.1"
            android:layout_marginBottom="4dp"
            android:layout_marginStart="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Used by riders to find your exact location."
            android:textSize="12sp"
            android:textColor="#8E7164"
            android:layout_marginBottom="20dp"
            android:layout_marginStart="4dp"/>

        <!-- ── Subdivision Spinner ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subdivision / Area"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#5A4136"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <Spinner
            android:id="@+id/spinnerSubdivision"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_role_unselected"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginBottom="20dp"/>

        <!-- ── Block and Lot Row ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <!-- Block -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Block"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#5A4136"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="4dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxBackgroundColor="#F4F4F0"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxStrokeColor="#A04100">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etBlock"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:hint="e.g. 4"
                        android:inputType="text"
                        android:paddingHorizontal="20dp"
                        android:background="@null"
                        android:textColor="#1A1C1A"
                        android:textSize="14sp"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Lot -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lot"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#5A4136"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="4dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxBackgroundColor="#F4F4F0"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxStrokeColor="#A04100">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etLot"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:hint="e.g. 12"
                        android:inputType="text"
                        android:paddingHorizontal="20dp"
                        android:background="@null"
                        android:textColor="#1A1C1A"
                        android:textSize="14sp"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- ── Street ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Street"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#5A4136"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxBackgroundColor="#F4F4F0"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="2dp"
            app:boxStrokeColor="#A04100"
            android:layout_marginBottom="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etStreet"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="e.g. Ilang-Ilang St."
                android:inputType="textPostalAddress"
                android:paddingHorizontal="20dp"
                android:background="@null"
                android:textColor="#1A1C1A"
                android:textSize="14sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Landmark ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Landmark (optional)"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#5A4136"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxBackgroundColor="#F4F4F0"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="2dp"
            app:boxStrokeColor="#A04100"
            android:layout_marginBottom="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLandmark"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="e.g. near sari-sari store, blue gate"
                android:inputType="text"
                android:paddingHorizontal="20dp"
                android:background="@null"
                android:textColor="#1A1C1A"
                android:textSize="14sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Full Address (auto-built) ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full Address"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#5A4136"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxBackgroundColor="#F4F4F0"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="2dp"
            app:boxStrokeColor="#A04100"
            android:layout_marginBottom="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:hint="Auto-filled from fields above"
                android:inputType="textMultiLine|textPostalAddress"
                android:paddingHorizontal="20dp"
                android:paddingVertical="16dp"
                android:background="@null"
                android:textColor="#1A1C1A"
                android:textSize="14sp"
                android:gravity="top"/>
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 You can pin your exact spot on the map after signing up."
            android:textSize="11sp"
            android:textColor="#8E7164"
            android:layout_marginBottom="32dp"
            android:layout_marginStart="4dp"
            android:lineSpacingMultiplier="1.4"/>

        <!-- ── Role Selection ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="I want to"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#5A4136"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:id="@+id/btnRoleCustomer"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_role_selected"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛒"
                    android:textSize="20sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Buy Food"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#A04100"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnRoleSeller"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_role_unselected"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🍳"
                    android:textSize="20sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sell Food"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#77574D"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:indeterminateTint="#A04100"
            android:visibility="gone"
            android:layout_marginBottom="12dp"/>

        <!-- Register Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Create Account"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#A04100"
            app:cornerRadius="28dp"
            android:layout_marginBottom="24dp"/>

        <!-- Login Link -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? "
                android:textColor="#77574D"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign In"
                android:textColor="#A04100"
                android:textStyle="bold"
                android:textSize="14sp"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>