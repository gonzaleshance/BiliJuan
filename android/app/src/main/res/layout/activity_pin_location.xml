<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Full-screen OSMDroid map -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"/>

    <!-- Fixed Center Pointer (Optimized UX Pointer) -->
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:paddingBottom="48dp"
        android:elevation="12dp">
        
        <!-- Outer Circle / Target area -->
        <View
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_white_circle"
            android:backgroundTint="#3327AE60"
            android:alpha="0.5"/>

        <!-- The Pin -->
        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_location"
            app:tint="@color/primary" />
            
        <!-- Precise tip dot -->
        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_white_circle"
            android:backgroundTint="@color/primary"/>
    </FrameLayout>

    <!-- TOP SECTION: Merged Search, Instruction, and Address (Seller-Style Consistency) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:layout_margin="12dp"
        android:background="@drawable/bg_card_white"
        android:backgroundTint="#EEFFFFFF"
        android:padding="14dp"
        android:elevation="6dp">

        <!-- Back + title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@android:color/transparent"
                app:tint="@color/primary"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Set Delivery Location"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <!-- My Location button -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnMyLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_location"
                app:fabSize="mini"
                app:backgroundTint="@color/primary"
                app:tint="@color/on_primary"
                app:elevation="2dp"/>
        </LinearLayout>

        <!-- Search Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_search_white"
            android:backgroundTint="#F1F2F6"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                app:tint="@color/text_secondary"/>

            <EditText
                android:id="@+id/etSearchLocation"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Search street or landmark"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:imeOptions="actionSearch"
                android:inputType="textPostalAddress"
                android:layout_marginStart="10dp"
                android:paddingEnd="8dp"/>

            <ProgressBar
                android:id="@+id/progressSearch"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:visibility="gone"
                android:indeterminateTint="@color/primary"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvInstruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Drag the map to position your exact delivery spot under the pin."
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="8dp"/>

        <!-- Detected Address Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_surface_section"
            android:padding="10dp">
            
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_location"
                app:tint="@color/primary"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvCurrentAddress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Detecting location..."
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"/>
            
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerifyExternal"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Verify"
                android:textSize="11sp"
                android:textColor="@color/primary"
                app:icon="@drawable/google"
                app:iconTint="@null"
                app:iconSize="14dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="8dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Suggestions List (Floating below the top card) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSuggestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="200dp"
        android:layout_marginHorizontal="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp"
        android:visibility="gone">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSuggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="250dp"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- BOTTOM SECTION: Confirm Pin -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bg_card_top_rounded"
        android:backgroundTint="#FFFFFF"
        android:elevation="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmPin"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Deliver to this location"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/on_primary"
            android:backgroundTint="@color/primary"
            app:cornerRadius="30dp"
            app:elevation="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSkipPin"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Cancel"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>