<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- OSMDroid MapView — full screen -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"/>

    <!-- Top instruction card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:layout_margin="16dp"
        android:background="#EEFFFFFF"
        android:padding="16dp"
        android:elevation="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pin Your Location"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1C1A"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvInstruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap anywhere on the map to drop your delivery pin inside Saranay."
            android:textSize="13sp"
            android:textColor="#77574D"
            android:lineSpacingMultiplier="1.4"/>

    </LinearLayout>

    <!-- Bottom action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#EEFFFFFF"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmPin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Confirm Location"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#A04100"
            app:cornerRadius="28dp"
            android:enabled="false"
            android:layout_marginBottom="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSkipPin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Skip for now"
            android:textSize="14sp"
            android:textColor="#77574D"
            android:backgroundTint="@android:color/transparent"
            app:cornerRadius="24dp"
            app:strokeColor="#E2BFB033"
            app:strokeWidth="1dp"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>