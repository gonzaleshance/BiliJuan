<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- Header -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="#FFFFFF">

            <!-- Back Button Removed -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Order History"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2D3436"
                android:gravity="center"/>

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F8F9FA"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:paddingBottom="80dp">

        <!-- Filter Chips container with hardcoded background to prevent black flash -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingVertical="16dp"
            android:background="#F8F9FA">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp">

                <TextView
                    android:id="@+id/chipActive"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Active"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:paddingHorizontal="24dp"
                    android:background="@drawable/bg_chip_active"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/chipHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="History"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#636E72"
                    android:gravity="center"
                    android:paddingHorizontal="24dp"
                    android:background="@drawable/bg_chip_inactive"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Empty State -->
        <TextView
            android:id="@+id/emptyOrders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No orders here yet."
            android:textSize="14sp"
            android:textColor="#636E72"
            android:gravity="center"
            android:paddingVertical="64dp"
            android:visibility="gone"
            android:background="#F8F9FA"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvOrders"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="16dp"
            android:clipToPadding="false"
            android:background="#F8F9FA"
            tools:listitem="@layout/item_seller_order_row"/>
    </LinearLayout>

    <!-- Custom Store Bottom Nav -->
    <include layout="@layout/layout_store_bottom_nav"
        android:id="@+id/storeNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>