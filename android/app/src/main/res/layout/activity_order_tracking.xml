<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <!-- Green Header Status Banner -->
    <LinearLayout
        android:id="@+id/layoutHeaderStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#27AE60"
        android:paddingHorizontal="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp">

        <!-- Back button and Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@android:color/transparent"
                app:tint="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Track Order"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_white_circle"
                android:backgroundTint="#33FFFFFF"
                android:gravity="center">

                <ImageView
                    android:id="@+id/ivStatusIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_delivery_dining"
                    app:tint="#FFFFFF"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Status"
                    android:textSize="12sp"
                    android:textColor="#CCFFFFFF"/>

                <TextView
                    android:id="@+id/tvCurrentStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Out for Delivery"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutEta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ETA"
                    android:textSize="11sp"
                    android:textColor="#CCFFFFFF"/>

                <TextView
                    android:id="@+id/tvEta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10-15 mins"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Rejection Alert Card (Hidden by default) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRejection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#FFC5C2"
                app:cardBackgroundColor="#FEEBEB"
                android:layout_marginBottom="16dp"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Order Rejected"
                        android:textStyle="bold"
                        android:textColor="#EB4D4B"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/tvRejectionReason"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reason: Seller is out of stock"
                        android:textColor="#636E72"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- MAP (Hidden by default) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMap"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F2F6"
                android:layout_marginBottom="16dp"
                android:visibility="gone">
                <org.osmdroid.views.MapView
                    android:id="@+id/mapView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Order Progress Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F2F6"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Step 1: Confirmed/Preparing -->
                    <include layout="@layout/item_progress_step" android:id="@+id/stepPreparing"/>
                    <View android:id="@+id/linePreparing" android:layout_width="2dp" android:layout_height="30dp" android:layout_marginStart="21dp" android:background="#27AE60"/>

                    <!-- Step 2: Out for Delivery -->
                    <include layout="@layout/item_progress_step" android:id="@+id/stepOnTheWay"/>
                    <View android:id="@+id/lineOnTheWay" android:layout_width="2dp" android:layout_height="30dp" android:layout_marginStart="21dp" android:background="#F1F2F6"/>

                    <!-- Step 3: Delivered -->
                    <include layout="@layout/item_progress_step" android:id="@+id/stepDelivered"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Order Details Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F2F6"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Order Details"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#2D3436"
                        android:layout_marginBottom="16dp"/>

                    <!-- Item List Container -->
                    <LinearLayout
                        android:id="@+id/layoutOrderItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:animateLayoutChanges="true"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F2F6" android:layout_marginVertical="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Total" android:textSize="16sp" android:textStyle="bold" android:textColor="#2D3436"/>
                        <TextView android:id="@+id/tvTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₱0" android:textSize="16sp" android:textStyle="bold" android:textColor="#27AE60"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Delivery Address Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F2F6"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delivery Address"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#2D3436"
                        android:layout_marginBottom="14dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_location"
                            app:tint="#27AE60"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">

                            <TextView
                                android:id="@+id/tvAddressMain"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="123 Main St, Saranay"
                                android:textSize="14sp"
                                android:textColor="#2D3436"/>

                            <TextView
                                android:id="@+id/tvAddressSub"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Saranay"
                                android:textSize="12sp"
                                android:textColor="#636E72"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Contact Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F2F6"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contact Seller/Rider"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#2D3436"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <ImageView
                            android:id="@+id/ivContactAvatar"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_person"
                            android:background="@drawable/bg_white_circle"
                            android:padding="4dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">

                            <TextView
                                android:id="@+id/tvContactName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Maria's Kitchen"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#2D3436"/>

                            <TextView
                                android:id="@+id/tvContactPhone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+63 912 345 6789"
                                android:textSize="13sp"
                                android:textColor="#636E72"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCall"
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_weight="1"
                            android:text="Call"
                            app:icon="@drawable/ic_phone"
                            android:textAllCaps="false"
                            android:layout_marginEnd="8dp"
                            android:backgroundTint="#27AE60"
                            android:textColor="#FFFFFF"
                            app:iconTint="#FFFFFF"
                            app:cornerRadius="14dp"
                            app:elevation="0dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMessage"
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_weight="1"
                            android:text="Message"
                            app:icon="@drawable/ic_notifications"
                            android:textAllCaps="false"
                            android:layout_marginStart="8dp"
                            android:backgroundTint="#F1F2F6"
                            android:textColor="#2D3436"
                            app:iconTint="#2D3436"
                            app:cornerRadius="14dp"
                            app:elevation="0dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>