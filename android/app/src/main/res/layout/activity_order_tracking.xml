<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF9F5">

    <!-- Full-screen live map -->
    <fragment
        android:id="@+id/mapTracking"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Top status bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:background="#EEF9F5FA"
        android:paddingHorizontal="20dp"
        android:paddingVertical="14dp"
        android:elevation="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LIVE TRACKING"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#77574D"
            android:letterSpacing="0.1"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvOrderStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏳ Waiting for confirmation…"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1A1C1A"/>
    </LinearLayout>

    <!-- Bottom seller contact card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp"
        android:elevation="8dp">

        <!-- Seller info row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <!-- Seller avatar -->
            <LinearLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="#FFDBD0"
                android:gravity="center"
                android:layout_marginEnd="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🍳"
                    android:textSize="20sp"/>
            </LinearLayout>

            <!-- Seller name + phone -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSellerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seller Name"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1C1A"/>

                <TextView
                    android:id="@+id/tvSellerPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="09XX XXX XXXX"
                    android:textSize="12sp"
                    android:textColor="#77574D"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Call seller button -->
            <LinearLayout
                android:id="@+id/btnCallSeller"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="#FFF3EE"
                android:gravity="center"
                android:layout_marginEnd="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_phone"
                    app:tint="#A04100"/>
            </LinearLayout>

            <!-- SMS customer button -->
            <LinearLayout
                android:id="@+id/btnSmsCustomer"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="#FFF3EE"
                android:gravity="center">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_notifications"
                    app:tint="#A04100"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Map legend -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Orange = Rider -->
            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="#FF6B00"
                android:layout_marginEnd="6dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rider"
                android:textSize="11sp"
                android:textColor="#77574D"
                android:layout_marginEnd="16dp"/>

            <!-- Blue = You -->
            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="#059EFF"
                android:layout_marginEnd="6dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You"
                android:textSize="11sp"
                android:textColor="#77574D"
                android:layout_marginEnd="16dp"/>

            <!-- Green = Seller -->
            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="#27AE60"
                android:layout_marginEnd="6dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Seller"
                android:textSize="11sp"
                android:textColor="#77574D"/>

        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
