<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#F1F2F6"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#FFFFFF">

        <!-- Top Row: Icon + Customer + Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#FFFFFF">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_primary_light_circle">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_person"
                    app:tint="#27AE60"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:background="#FFFFFF">
                <TextView
                    android:id="@+id/tvCustomer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Customer Name"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2D3436"
                    android:maxLines="1"
                    android:ellipsize="end"/>
                <TextView
                    android:id="@+id/tvProduct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Product Names..."
                    android:textSize="14sp"
                    android:textColor="#636E72"
                    android:layout_marginTop="2dp"
                    android:maxLines="1"
                    android:ellipsize="end"/>
            </LinearLayout>

            <TextView
                android:id="@+id/chipStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#27AE60"/>
        </LinearLayout>

        <!-- Address Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            android:background="#FFFFFF">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_location"
                app:tint="#B2BEC3"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvAddress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Delivery Address"
                android:textSize="13sp"
                android:textColor="#636E72"
                android:maxLines="1"
                android:ellipsize="end"/>
            
            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0 km"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#27AE60"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Price & Time Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:background="#FFFFFF">

            <TextView
                android:id="@+id/tvAmount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="₱0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#27AE60"/>

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2 mins ago"
                android:textSize="13sp"
                android:textColor="#B2BEC3"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F1F2F6"
            android:layout_marginTop="16dp"/>

        <!-- Bottom Action Layout (Fixed Flipped Text) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:background="#FFFFFF">

            <!-- Primary Action (Accept / Cook / Delivery) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdvance"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1.2"
                android:text="Accept Order"
                android:textStyle="bold"
                android:textColor="#27AE60"
                android:textSize="12sp"
                android:padding="0dp"
                android:visibility="gone"/>

            <!-- Centered Reject Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReject"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="0.8"
                android:text="Reject"
                android:textStyle="bold"
                android:textColor="#EB4D4B"
                android:textSize="12sp"
                android:padding="0dp"
                android:visibility="gone"/>

            <!-- Track Action (Icon fixed) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewMap"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Track"
                android:textStyle="bold"
                android:textColor="#27AE60"
                android:textSize="12sp"
                app:icon="@drawable/ic_location"
                app:iconGravity="textStart"
                app:iconSize="16dp"
                app:iconTint="#27AE60"
                android:padding="0dp"
                android:visibility="gone"/>
                
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>