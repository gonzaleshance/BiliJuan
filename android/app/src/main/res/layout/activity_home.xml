<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:titleEnabled="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#27AE60"
                android:paddingTop="48dp"
                android:paddingBottom="32dp"
                android:paddingHorizontal="24dp">

                <!-- Greeting row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvGreeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kumain na tayo!"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Discover local flavors today"
                            android:textSize="14sp"
                            android:textColor="#CCFFFFFF"/>
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp">
                        <ImageButton
                            android:id="@+id/btnNotification"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_notifications"
                            android:background="@drawable/bg_white_circle"
                            android:backgroundTint="#33FFFFFF"
                            app:tint="#FFFFFF"
                            android:padding="12dp"/>
                        <View
                            android:id="@+id/notifDot"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="10dp"
                            android:background="@drawable/bg_notification_dot"
                            android:visibility="gone"/>
                    </FrameLayout>
                </LinearLayout>

                <!-- Search bar -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/searchBarContainer"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="20dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_search"
                            app:tint="#636E72"/>

                        <EditText
                            android:id="@+id/etSearch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Search for food or store..."
                            android:textSize="15sp"
                            android:textColorHint="#636E72"
                            android:textColor="#2D3436"
                            android:background="@android:color/transparent"
                            android:imeOptions="actionSearch"
                            android:inputType="text"
                            android:paddingStart="12dp"
                            android:textCursorDrawable="@null"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </com.google.android.material.appbar.CollapsingToolbarLayout>

        <!-- Static Tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#27AE60"
            android:paddingHorizontal="24dp">

            <TextView
                android:id="@+id/tabFood"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Food"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="#27AE60"
                android:background="@drawable/bg_tab_active_white"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tabStore"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Store"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:background="@android:color/transparent"
                android:layout_marginStart="6dp"/>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollViewMain"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="100dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:animateLayoutChanges="true">

                <!-- FOOD TAB SECTION -->
                <LinearLayout
                    android:id="@+id/sectionFood"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Category chips -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:paddingVertical="16dp">
                        <LinearLayout
                            android:id="@+id/categoryChipsContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingHorizontal="24dp"/>
                    </HorizontalScrollView>

                    <!-- Popular header -->
                    <LinearLayout
                        android:id="@+id/layoutPopularHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="24dp"
                        android:paddingBottom="12dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🔥 Popular this week"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#2D3436"/>
                        <TextView
                            android:id="@+id/tvSeeAllPopular"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="See all"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#27AE60"
                            android:padding="4dp"/>
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvPopular"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:clipToPadding="false"
                            android:paddingHorizontal="24dp"
                            android:visibility="invisible"/>
                        <LinearLayout
                            android:id="@+id/shimmerPopular"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:orientation="horizontal"
                            android:paddingHorizontal="24dp">
                            <include layout="@layout/item_shimmer" android:layout_width="240dp" android:layout_height="match_parent" android:layout_marginEnd="16dp"/>
                        </LinearLayout>
                    </FrameLayout>

                    <!-- Listings header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="24dp"
                        android:paddingTop="24dp"
                        android:paddingBottom="12dp">
                        <TextView
                            android:id="@+id/tvListingsLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="✨ Fresh for you"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#2D3436"/>
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvListings"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:visibility="invisible"/>
                        <LinearLayout
                            android:id="@+id/shimmerListings"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <include layout="@layout/item_shimmer"/>
                            <include layout="@layout/item_shimmer"/>
                        </LinearLayout>
                    </FrameLayout>

                    <TextView
                        android:id="@+id/emptyListings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Wala pang available na pagkain."
                        android:textSize="14sp"
                        android:textColor="#636E72"
                        android:gravity="center"
                        android:paddingVertical="64dp"
                        android:visibility="gone"/>
                </LinearLayout>

                <!-- STORE TAB SECTION -->
                <LinearLayout
                    android:id="@+id/sectionStore"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView
                        android:id="@+id/emptyStores"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Wala pang available na store."
                        android:textSize="14sp"
                        android:textColor="#636E72"
                        android:gravity="center"
                        android:paddingVertical="64dp"
                        android:visibility="gone"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvStores"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="20dp"
                        android:paddingTop="16dp"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- SEARCH RESULTS VIEW -->
    <LinearLayout
        android:id="@+id/layoutSearchResults"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F8F9FA"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:visibility="gone"
        android:animateLayoutChanges="true">
        <TextView
            android:id="@+id/tvSearchCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:text="Search Results"
            android:textStyle="bold"
            android:textColor="#636E72"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSearchResults"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="8dp"
            android:clipToPadding="false"
            android:paddingBottom="100dp"/>
    </LinearLayout>

    <include
        android:id="@+id/customerNav"
        layout="@layout/layout_customer_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom" />

    <!-- FAB for Cart with Badge -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnCart"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="100dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="32dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFF"
        app:strokeWidth="0dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_cart"
                app:tint="#27AE60"/>

            <TextView
                android:id="@+id/tvCartBadge"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_notification_dot"
                android:gravity="center"
                android:text="1"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:elevation="4dp"/>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>