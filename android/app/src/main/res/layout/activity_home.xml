<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Green Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/primary"
        android:paddingHorizontal="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="0dp">

        <!-- Greeting row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kumain na tayo!"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_primary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="What are you craving today?"
                    android:textSize="13sp"
                    android:textColor="#CCFFFFFF"/>
            </LinearLayout>

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp">

                <ImageButton
                    android:id="@+id/btnNotification"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_notifications"
                    android:background="@android:color/transparent"
                    app:tint="@color/on_primary"/>

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_notification_dot"/>
            </FrameLayout>
        </LinearLayout>

        <!-- Search bar -->
        <LinearLayout
            android:id="@+id/searchBar"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_search_white"
            android:paddingHorizontal="14dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                app:tint="@color/text_hint"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Search food or store..."
                android:textSize="13sp"
                android:textColor="@color/text_hint"/>
        </LinearLayout>

        <!-- Food / Store top tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tabFood"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Food"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/primary"
                android:background="@drawable/bg_tab_active_white"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/tabStore"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Store"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="#CCFFFFFF"
                android:background="@android:color/transparent"
                android:layout_marginStart="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">


        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

        <!-- FOOD TAB -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/sectionFood"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="80dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Category chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingVertical="12dp">

                    <LinearLayout
                        android:id="@+id/categoryChipsContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"/>
                </HorizontalScrollView>

                <!-- Popular this week header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Popular this week"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvSeeAllPopular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See all"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"/>
                </LinearLayout>

                <!-- Shimmer for popular -->
                <LinearLayout
                    android:id="@+id/shimmerPopular"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:visibility="visible">

                    <include layout="@layout/item_shimmer"
                        android:layout_width="200dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="12dp"/>
                    <include layout="@layout/item_shimmer"
                        android:layout_width="200dp"
                        android:layout_height="match_parent"/>
                </LinearLayout>

                <!-- Popular RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPopular"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:clipToPadding="false"
                    android:paddingHorizontal="16dp"
                    android:visibility="gone"/>

                <!-- Fresh for you header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:id="@+id/tvListingsLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Fresh for you"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>

                <!-- Shimmer for listings -->
                <LinearLayout
                    android:id="@+id/shimmerListings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <include layout="@layout/item_shimmer"/>
                    <include layout="@layout/item_shimmer"/>
                    <include layout="@layout/item_shimmer"/>
                </LinearLayout>

                <!-- Food listings -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvListings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone"/>

                <!-- Empty state -->
                <TextView
                    android:id="@+id/emptyListings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Wala pang available na pagkain."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:paddingVertical="40dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>


        <!-- STORE TAB -->
        <LinearLayout
            android:id="@+id/sectionStore"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/emptyStores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Wala pang available na store."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:paddingVertical="40dp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvStores"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="80dp"
                android:clipToPadding="false"/>
        </LinearLayout>

    </FrameLayout>

    <!-- Bottom Nav -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/surface"
        app:menu="@menu/bottom_nav_customer"
        app:itemIconTint="@color/bottom_nav_tint"
        app:itemTextColor="@color/bottom_nav_tint"
        app:labelVisibilityMode="labeled"
        android:elevation="16dp"/>

</LinearLayout>