<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/market_background">

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="88dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header: greeting + avatar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_surface"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good morning! 👋"
                        android:textColor="@color/market_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="📍 Saranay, Zone A"
                        android:textColor="@color/market_text_soft"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvAvatar"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:gravity="center"
                    android:text="🛒"
                    android:textSize="18sp" />
            </LinearLayout>

            <!-- Search bar -->
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_input_rounded"
                android:hint="🔍  Search food, sellers..."
                android:paddingHorizontal="20dp"
                android:textColor="@color/market_text"
                android:textColorHint="@color/market_text_soft"
                android:textSize="15sp" />

            <!-- Category chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_fresh"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="🍽 All"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_chip_category"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="🍚 Rice Meal"
                        android:textColor="@color/market_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_chip_category"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="🍢 Snacks"
                        android:textColor="@color/market_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_chip_category"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="🥤 Drinks"
                        android:textColor="@color/market_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_chip_category"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="🍜 Ulam"
                        android:textColor="@color/market_primary" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Food listings section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_surface_section"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nearby Sellers"
                        android:textColor="@color/market_text"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See all →"
                        android:textColor="@color/market_primary"
                        android:textStyle="bold"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- RecyclerView will replace this in Phase 3 -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFoodListings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Floating bottom navigation -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="64dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp">

        <TextView
            android:id="@+id/navHome"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:gravity="center"
            android:text="🏠"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/navCart"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:gravity="center"
            android:text="🛒"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/navOrders"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:gravity="center"
            android:text="📦"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/navProfile"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:gravity="center"
            android:text="👤"
            android:textSize="22sp" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
