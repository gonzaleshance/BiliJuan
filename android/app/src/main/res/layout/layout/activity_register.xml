<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/market_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Brand badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_surface"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍱"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="BiliJuan"
                android:textColor="@color/market_secondary"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Headline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Join the community"
            android:textColor="@color/market_text"
            android:textSize="34sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Create your account and start ordering from local sellers."
            android:textColor="@color/market_text_soft"
            android:textSize="15sp"
            android:lineSpacingExtra="3dp" />

        <!-- Form card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Full Name -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Full Name"
                app:boxBackgroundMode="filled"
                app:boxBackgroundColor="@color/market_surface_low"
                app:boxCornerRadiusTopStart="28dp"
                app:boxCornerRadiusTopEnd="28dp"
                app:boxCornerRadiusBottomStart="28dp"
                app:boxCornerRadiusBottomEnd="28dp"
                app:hintTextColor="@color/market_text_soft">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/market_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Email -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Email address"
                app:boxBackgroundMode="filled"
                app:boxBackgroundColor="@color/market_surface_low"
                app:boxCornerRadiusTopStart="28dp"
                app:boxCornerRadiusTopEnd="28dp"
                app:boxCornerRadiusBottomStart="28dp"
                app:boxCornerRadiusBottomEnd="28dp"
                app:hintTextColor="@color/market_text_soft">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/market_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Password"
                app:boxBackgroundMode="filled"
                app:boxBackgroundColor="@color/market_surface_low"
                app:boxCornerRadiusTopStart="28dp"
                app:boxCornerRadiusTopEnd="28dp"
                app:boxCornerRadiusBottomStart="28dp"
                app:boxCornerRadiusBottomEnd="28dp"
                app:endIconMode="password_toggle"
                app:hintTextColor="@color/market_text_soft">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="@color/market_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Phone -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Phone number"
                app:boxBackgroundMode="filled"
                app:boxBackgroundColor="@color/market_surface_low"
                app:boxCornerRadiusTopStart="28dp"
                app:boxCornerRadiusTopEnd="28dp"
                app:boxCornerRadiusBottomStart="28dp"
                app:boxCornerRadiusBottomEnd="28dp"
                app:hintTextColor="@color/market_text_soft">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:textColor="@color/market_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Divider label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="4dp"
                android:text="Delivery location"
                android:textColor="@color/market_secondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <!-- Phase & Lot row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Phase"
                    app:boxBackgroundMode="filled"
                    app:boxBackgroundColor="@color/market_surface_low"
                    app:boxCornerRadiusTopStart="28dp"
                    app:boxCornerRadiusTopEnd="28dp"
                    app:boxCornerRadiusBottomStart="28dp"
                    app:boxCornerRadiusBottomEnd="28dp"
                    app:hintTextColor="@color/market_text_soft">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPhase"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/market_text" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:hint="Lot"
                    app:boxBackgroundMode="filled"
                    app:boxBackgroundColor="@color/market_surface_low"
                    app:boxCornerRadiusTopStart="28dp"
                    app:boxCornerRadiusTopEnd="28dp"
                    app:boxCornerRadiusBottomStart="28dp"
                    app:boxCornerRadiusBottomEnd="28dp"
                    app:hintTextColor="@color/market_text_soft">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etLot"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/market_text" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Zone label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="6dp"
                android:text="Zone"
                android:textColor="@color/market_text_soft"
                android:textSize="13sp" />

            <!-- Zone spinner -->
            <Spinner
                android:id="@+id/spinnerZone"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_rounded"
                android:entries="@array/zones"
                android:paddingHorizontal="16dp" />

            <!-- Register button -->
            <Button
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_gradient_primary"
                android:text="Create Account"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Progress bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:indeterminateTint="@color/market_primary_container"
                android:visibility="gone" />

            <!-- Login link -->
            <TextView
                android:id="@+id/tvLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:padding="8dp"
                android:text="Already have an account? Sign in"
                android:textColor="@color/market_primary"
                android:textStyle="bold" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
